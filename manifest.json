{
  "manifest_version": 3,
  "name": "Scroll Blocker",
  "version": "1.0",
  "description": "Prevents infinite scroll on YouTube Shorts and Instagram Reels.",
  "permissions": ["storage", "scripting", "activeTab", "tabs"],
  "host_permissions": ["*://*.youtube.com/*", "*://*.instagram.com/*", "*://*.tiktok.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*", "*://*.instagram.com/*", "*://*.tiktok.com/*"],
      "js": [
        "content/scrollBlocker.js",
        "content/youtube.js",
        "content/instagram.js",
        "content/tiktok.js",
        "content/router.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
